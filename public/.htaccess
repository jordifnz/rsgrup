Options -Indexes
ServerSignature Off

# Forzar HTTPS (descomenta cuando tengas SSL activo)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteEngine On

# ============================================================
# BLOQUEO DE ARCHIVOS SENSIBLES Y RUTAS DE RECONOCIMIENTO
# ============================================================

<FilesMatch "^\.(env|env\..*|envrc)$">
    Require all denied
</FilesMatch>

<FilesMatch "(\.bak|\.backup|\.old|\.orig|\.sql|\.dump|\.log|\.sh|\.bash|\.zsh|\.swp|\.swo|\.DS_Store|Thumbs\.db|\.htpasswd|\.htaccess\.bak|composer\.lock|package-lock\.json|yarn\.lock|Makefile|Dockerfile|\.dockerignore)$">
    Require all denied
</FilesMatch>

RewriteRule ^\.(git|svn|hg)(/|$) - [F,L]
RewriteRule (^\.|\/\.)git - [F,L]
RewriteRule ^(vendor|node_modules)(/|$) - [F,L]

RewriteRule ^(wp-login|wp-admin|wp-config|xmlrpc|wp-includes|wp-content)(\.php)?(/|$) - [F,L]
RewriteRule ^(\.well-known/cpanel|cgi-bin|phpmyadmin|pma|myadmin|mysqladmin|admin/pma|dbadmin|mypma|php-my-admin)(/|$) - [F,L]
RewriteRule ^(shell|cmd|config\.bak|site\.bak|backup|database\.sql|dump\.sql|db\.sql|install\.php|setup\.php|test\.php|info\.php|phpinfo\.php) - [F,L]

<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (libwww-perl|python-requests|Go-http-client|zgrab|masscan|nmap|sqlmap|nikto|curl\/[0-7]|wget\/[0-1]|WPScan|Nuclei|Dirbuster|gobuster|feroxbuster) [NC]
    RewriteRule .* - [F,L]
</IfModule>

<LimitExcept GET POST HEAD OPTIONS>
    Require all denied
</LimitExcept>

RewriteRule ^(config|src|templates|logs|sql)(/|$) - [F,L]

RewriteCond %{REQUEST_URI} ^/uploads/
RewriteRule \.php$ - [F,L]

# ============================================================
# ENRUTAMIENTO
# ============================================================

RewriteCond %{REQUEST_URI} ^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/(.*)$ ../api/v1/index.php [QSA,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# ============================================================
# CABECERAS DE SEGURIDAD
# ============================================================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # HSTS: activa SOLO cuando tengas SSL estable
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # CSP
    # form-action incluye los dominios de PayPal porque el POST /inscribir
    # hace un redirect 302 hacia paypal.com, y algunos navegadores aplican
    # form-action tambien al destino de la redireccion.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.paypal.com https://www.paypalobjects.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https:; frame-src https://www.paypal.com https://www.sandbox.paypal.com; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.gstatic.com https://api.paypal.com https://api.sandbox.paypal.com; form-action 'self' https://www.paypal.com https://www.sandbox.paypal.com https://*.paypal.com; base-uri 'self';"

    Header always unset Server
    Header always unset X-Powered-By
</IfModule>

# ============================================================
# RENDIMIENTO
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css               "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/svg+xml         "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType application/pdf        "access plus 1 week"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain text/xml
</IfModule>
