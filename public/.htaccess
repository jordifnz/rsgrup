Options -Indexes
ServerSignature Off

# Forzar HTTPS en producción (descomenta cuando tengas SSL activo)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteEngine On

# --- SEGURIDAD: bloquear acceso a .git y archivos sensibles ---
RewriteRule ^\.(git|env|htpasswd)(/|$) - [F,L]
RewriteRule (^\.|\/\.)git - [F,L]

# Bloquear acceso directo a directorios sensibles fuera de public/
RewriteRule ^(config|src|templates|logs|sql)(/|$) - [F,L]

# Bloquear ejecución PHP en uploads
RewriteCond %{REQUEST_URI} ^/uploads/
RewriteRule \.php$ - [F,L]

# --- API: redirigir /api/* a api/v1/index.php ---
RewriteCond %{REQUEST_URI} ^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/(.*)$ ../api/v1/index.php [QSA,L]

# --- Router principal: todo lo demás a index.php ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Cabeceras de seguridad
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Cache de assets estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css               "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/svg+xml          "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
</IfModule>

# Compresión
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain
</IfModule>
